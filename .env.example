# FDE Knowledge Hub - 环境配置示例

# ─────────────────────────────────────────────────────────
# SiliconFlow API 配置（Embedding 推荐，免费额度充足，OpenAI 兼容）
# 获取 Key：https://cloud.siliconflow.cn/account/ak
# 优先级最高：SILICONFLOW_API_KEY 存在时，Embedding 优先使用 SiliconFlow
# ─────────────────────────────────────────────────────────
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# 国际版：https://api.siliconflow.com/v1
# 国内版可用模型（1024 维）：BAAI/bge-m3、BAAI/bge-large-zh-v1.5
# 国际版可用模型：Qwen/Qwen3-Embedding-0.6B（1024 维）、Qwen/Qwen3-Embedding-4B（2560 维）
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3

# ─────────────────────────────────────────────────────────
# MiniMax API 配置（对话模型，国内可直连）
# 获取 Key：https://www.minimaxi.com/user-center/basic-information/interface-key
# MiniMax 提供与 OpenAI 格式兼容的接口，用于对话功能（path/interview/review 命令）
# 国内版：https://api.minimax.chat/v1
# 国际版：https://api.minimaxi.chat/v1  （注意多一个 i）
# ─────────────────────────────────────────────────────────
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
MINIMAX_CHAT_MODEL=MiniMax-M2.7
# Embedding 已由 SiliconFlow 接管，此项仅在 SiliconFlow 未配置时作为回退
MINIMAX_EMBEDDING_MODEL=embo-01

# ─────────────────────────────────────────────────────────
# 原始 AI API Keys（以上优先级更高，二选一填写即可）
# ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# NotebookLM Configuration
NOTEBOOKLM_PROJECT_ID=your_project_id_here

# Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# Obsidian Configuration
OBSIDIAN_VAULT_PATH=/path/to/your/vault
OBSIDIAN_PLUGIN_DIR=/path/to/obsidian/plugins

# Automation Settings
ENABLE_AUTO_SYNC=true
SYNC_INTERVAL_HOURS=6
ENABLE_SPACED_REPETITION=true
REVIEW_INTERVAL_DAYS=7

# Development Settings
DEBUG=false
LOG_LEVEL=INFO
ENABLE_MOCK_MODE=false
